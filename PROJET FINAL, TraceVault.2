def buton_retour():
    fenetre_1.deiconify()
    # Correction : On ferme proprement les fenГӘtres enfants ouvertes sans casser Tkinter
    for widget in fenetre_1.winfo_children():
        if isinstance(widget, ctk.CTkToplevel):
            widget.destroy()

def changer_light():

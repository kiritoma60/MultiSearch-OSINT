    ctk.set_appearance_mode("dark")

# --- LE CЕ’UR DE LA RECHERCHE ---
def buton_valider():
    global current_entry, current_type
    if current_entry is None:
        return
    
    query = current_entry.get().strip()
    if not query:
        print("Erreur : Le champ est vide.")
        return
       
    print(f"Recherche de fou lancГ©e [{current_type}] pour : {query}")

    if current_type == "lieux":
        query_encoded = query.replace(" ", "+")

        webbrowser.open(f'https://www.google.com/maps/search/{query_encoded}')
        webbrowser.open(f"https://earth.google.com/web/search/{query}")

        result_text = f"""
        рҹ“Қ Lieu recherchГ© : {query}

        рҹ”Һ Infos rapides :
        - Recherche ouverte sur Google Maps
        - RГ©sultats basГ©s sur Google
        """

        print(result_text)
        return

    elif current_type == "email":
        # en general ca trouve rien
        webbrowser.open(f'https://www.google.com/search?q="{query}"')
        webbrowser.open(f'https://haveibeenpwned.com/')

    elif current_type == "pseudo":
        # Recherche sur Google + lien direct vers un outil de Namechecker (WhatsMyName)
        webbrowser.open(f'https://whatsmyname.app/?q={query}') # Super outil OSINT pour les pseudos en vrai ehehehe

    elif current_type == "nom_prenom":
        # Recherche combinГ©e exacte et rГ©seaux sociaux majeurs
        webbrowser.open(f'https://www.google.com/search?q="{query}"')
        webbrowser.open(f'https://www.google.com/search?q=site:linkedin.com/in/+"{query}"')
        webbrowser.open(f'https://www.google.com/search?q=site:facebook.com+"{query}"')

